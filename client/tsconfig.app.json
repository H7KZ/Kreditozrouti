{
	"extends": "@vue/tsconfig/tsconfig.dom.json",
	"include": ["env.d.ts", "src/**/*", "src/**/*.vue"],
	"compilerOptions": {
		"tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
		"verbatimModuleSyntax": false,
		"ignoreDeprecations": "6.0",

		"baseUrl": ".",
		"paths": {
			"@client/*": ["./src/*"],
			"@api/*": ["../api/src/*"],
			"@scraper/*": ["../scraper/src/*"],
			"@shared/*": ["../shared/*"],
			"kysely": ["./node_modules/kysely"]
		}
	}
}
