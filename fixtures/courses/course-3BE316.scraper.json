	"title": "Managerial Accounting and Performance Analysis",
	"title_cs": "Manažerské účetnictví a analýza výkonnosti",
	"title_en": "Managerial Accounting and Performance Analysis",
	"ects": "6 (1 ECTS kredit = 26 hodin studijní zátěže)",
