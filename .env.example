# .env.example — copy to .env and fill in the values.
# The .env file must never be committed to version control.

# ─── 1. Core

# Project name — used as a prefix for Docker container names and Traefik labels.
PROJECT=kreditozrouti

# Runtime environment: local | development | production
ENV=local

# Primary domain (used by Traefik routers and cookie scoping in production).
DOMAIN=localhost


# ─── 2. API

# Port the Express API listens on.
API_PORT=40080

# Full public URI of the API (used for self-referencing links).
API_URI=http://localhost:40080

# Top-level domain for session cookie scoping (no protocol, no path).
API_DOMAIN=localhost

# Comma-separated list of allowed CORS origins.
API_ALLOWED_ORIGINS=http://localhost:45173,http://localhost:40080

# Secret used to sign session cookies — use a long random string in production.
API_SESSION_SECRET=local

# Bearer token required by /commands routes (scraper triggers).
API_COMMAND_TOKEN=local

# Directory where uploaded files are stored (relative to api/ working directory).
API_FILE_DESTINATION=uploads/

# Set to true to bypass Redis response caching (useful on localhost to see live data).
API_CACHE_DISABLED=false


# ─── 3. Client

# Full public URI of the Vue client (used by the API to construct callback URLs).
CLIENT_URI=http://localhost:45173

# Vite dev server port.
VITE_CLIENT_PORT=45173

# API base URL injected into the client bundle at build time.
VITE_API_URL=http://localhost:40080

# Grafana Faro collector endpoint for browser telemetry (errors, web vitals).
# Leave empty to disable Faro in local development.
VITE_FARO_COLLECTOR_URL=http://localhost:41247/collect

# App version tag sent to Faro for release tracking (e.g. v1.2.3 or a git SHA).
VITE_APP_VERSION=local

# OTLP endpoint for API traces — points to Alloy's HTTP OTLP receiver (docker-compose.local.yml exposes :44318).
# Leave empty to disable trace export (spans are still created locally; trace_id appears in logs).
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:44318


# ─── 4. MySQL

MYSQL_USER=root
MYSQL_PASSWORD=root
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=kreditozrouti

# Full DSN used by Kysely — must match the credentials above.
MYSQL_URI=mysql://root:root@127.0.0.1:43306/kreditozrouti?sslmode=disable&schema=kreditozrouti


# ─── 5. Redis

REDIS_URI=redis://127.0.0.1:46379

# Leave empty if Redis has no password (default for local Docker setup).
REDIS_PASSWORD=


# ─── 6. Email

# Gmail address and App Password used by Nodemailer.
# Leave both empty to disable email sending entirely.
GOOGLE_USER=
GOOGLE_APP_PASSWORD=


# ─── 7. Monitoring

# Grafana admin credentials (used by the monitoring Docker Compose stack).
# Locally: http://localhost:43000 — default credentials below are fine for dev.
GRAFANA_ADMIN_USER=root
GRAFANA_ADMIN_PASSWORD=root
