{
    "name": "@kreditozrouti/scraper",
    "private": true,
    "version": "1.0.0",
    "main": "index.js",
    "scripts": {
        "dev": "dotenv -e ../.env -- tsx --watch src --exec ts-node -r tsconfig-paths/register src/index.ts --",
        "build": "tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json",
        "lint": "eslint ./src --ext .ts,.js",
        "format": "prettier --write .",
        "preview": "node dist/index.js",
        "type-check": "tsc --noEmit && tsc -p src/Tests/tsconfig.json --noEmit",
        "test": "vitest run",
        "test:regen": "dotenv -v FORCE_FIXTURES=1 -- vitest run",
        "generate-fixtures": "tsx --tsconfig tsconfig.json scripts/generate-fixtures.ts"
    },
    "dependencies": {
        "@opentelemetry/auto-instrumentations-node": "^0.77.0",
        "@opentelemetry/exporter-trace-otlp-proto": "^0.219.0",
        "@opentelemetry/sdk-node": "^0.219.0",
        "axios": "^1.16.0",
        "axios-retry": "^4.5.0",
        "bullmq": "^5.76.6",
        "bullmq-otel": "^1.3.1",
        "cheerio": "^1.2.0",
        "connect-redis": "^9.0.0",
        "dotenv": "^17.4.2",
        "ioredis": "^5.10.1",
        "moment": "^2.30.1",
        "pino": "^10.3.1",
        "turndown": "^7.2.4"
    },
    "devDependencies": {
        "@eslint/js": "^9.39.4",
        "@ianvs/prettier-plugin-sort-imports": "^4.7.1",
        "@types/node": "^25.6.2",
        "@types/turndown": "^5.0.6",
        "@typescript-eslint/parser": "^8.59.2",
        "eslint": "^9.39.4",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-import": "^2.32.0",
        "eslint-plugin-promise": "^7.3.0",
        "eslint-plugin-regexp": "^3.1.0",
        "eslint-plugin-unicorn": "^64.0.0",
        "globals": "^17.6.0",
        "prettier": "^3.8.3",
        "ts-node": "^10.9.2",
        "tsc-alias": "^1.8.17",
        "tsconfig-paths": "^4.2.0",
        "tsx": "^4.21.0",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.59.2",
        "vitest": "^4.1.8"
    }
}
