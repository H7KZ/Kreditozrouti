{
    "trailingComma": "none",
    "printWidth": 160,
    "tabWidth": 4,
    "semi": false,
    "singleQuote": true,
    "quoteProps": "as-needed",
    "jsxSingleQuote": true,
    "bracketSpacing": true,
    "bracketSameLine": false,
    "jsxBracketSameLine": false,
    "arrowParens": "avoid",
    "plugins": ["@ianvs/prettier-plugin-sort-imports"],
    "importOrder": ["<TYPES>", "<BUILT_IN_MODULES>", "<THIRD_PARTY_MODULES>", "^@shared/(.*)$", "^@scraper/(.*)$", "^[./]"],
    "importOrderTypeScriptVersion": "5.0.0",
    "overrides": [
        {
            "files": ["src/tests/fixtures/**"],
            "options": {
                "plugins": []
            }
        }
    ]
}
